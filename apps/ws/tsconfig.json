{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleDetection": "force",

    "types": ["bun"],

    "allowImportingTsExtensions": true,
    "noEmit": true,

    "verbatimModuleSyntax": true,

    "strict": true,
    "skipLibCheck": true
  }
}